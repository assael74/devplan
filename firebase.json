{
  "hosting": {
    "site": "devplan-b4454",
    "public": "build",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/public/abilities/submit",
        "function": {
          "functionId": "submitPublicAbilitiesInvite",
          "region": "europe-west1"
        }
      },
      {
        "source": "/share/abilities/**",
        "function": {
          "functionId": "shareAbilitiesInvite",
          "region": "europe-west1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}
